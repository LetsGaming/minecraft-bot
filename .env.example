# ── Timezone ──────────────────────────────────────────────────────────────────
# Sets log timestamps and scheduled-event times.
# Full list: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=Europe/Berlin

# ── Debug logging ─────────────────────────────────────────────────────────────
# Uncomment to enable verbose debug output.
# DEBUG=true

# ─────────────────────────────────────────────────────────────────────────────
# The variables below are only needed when using config.template.json.
# For a static config.json you can leave them blank or delete them.
# ─────────────────────────────────────────────────────────────────────────────

# ── Discord credentials ────────────────────────────────────────────────────────
# Discord Developer Portal → your app → Bot → Token
DISCORD_TOKEN=

# Discord Developer Portal → your app → General Information → Application ID
DISCORD_CLIENT_ID=

# Your Discord user ID.
# Enable Developer Mode (Settings → Advanced), then right-click your name → Copy User ID.
DISCORD_ADMIN_USER_ID=

# The Discord server (guild) ID where the bot should be active.
# Right-click your server name → Copy Server ID.
DISCORD_GUILD_ID=

# ── Minecraft API connection ───────────────────────────────────────────────────
# URL of the API wrapper running on your Minecraft server host.
# Same-machine example (API wrapper on the Docker host): http://host.docker.internal:3000
# Remote example:                                         http://192.168.1.10:3000
MC_API_URL=http://192.168.1.10:3000

# Shared secret set in the API wrapper config (leave empty if no API key is configured).
MC_API_KEY=

# ── Optional: additional Discord channels ─────────────────────────────────────
# These have sensible defaults in config.template.json (disabled).
# Set them here if you want to enable the corresponding features.
# DISCORD_NOTIFICATIONS_CHANNEL_ID=
# DISCORD_CHAT_BRIDGE_CHANNEL_ID=
# DISCORD_LEADERBOARD_CHANNEL_ID=
