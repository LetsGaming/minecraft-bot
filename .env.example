# ── minecraft-bot environment variables ──────────────────────────────────
# Copy to .env (git-ignored). Env vars override values in config.json.
# This allows Docker / Kubernetes secrets injection without config files.

# Discord bot credentials
DISCORD_TOKEN=your-discord-bot-token-here
DISCORD_CLIENT_ID=your-discord-application-id

# RCON password (applied to all servers unless per-server override is set)
RCON_PASSWORD=your-rcon-password

# Per-server RCON override (replace SURVIVAL with your server ID, uppercased)
# RCON_PASSWORD_SURVIVAL=server-specific-password

# API wrapper key (if using remote API server)
# MC_API_KEY=your-api-key

# ── Web dashboard (optional; "webui": { "enabled": true } in config.json) ──
# Discord application OAuth2 client secret (Developer Portal → OAuth2).
# Add http://localhost:8130/auth/callback (or your publicUrl + /auth/callback)
# to the application's redirect URIs.
# WEBUI_CLIENT_SECRET=your-oauth2-client-secret
# Cookie-signing key — any long random string (>= 16 chars).
# WEBUI_SESSION_SECRET=generate-a-long-random-string
