# ── minecraft-bot environment ─────────────────────────────────────────────
# Copy to .env (git-ignored) and fill in. This single file drives the whole
# Docker deployment — you should not need to edit docker-compose.yml.
#
#   cp .env.example .env
#   docker compose up -d                  # bot only
#   docker compose --profile web up -d    # bot + dashboard
#
# Two ways these values are used:
#   1. Seeding config.json — the template (config.template.json) has ${...}
#      placeholders filled from the DISCORD_* / MC_API_* vars below at first
#      start. (Prefer a hand-written static config? See MCBOT_CONFIG_FILE.)
#   2. Runtime overrides — DISCORD_TOKEN / DISCORD_CLIENT_ID / RCON_PASSWORD
#      also override config.json at load time (secrets injection).

# ── Discord (required) ────────────────────────────────────────────────────
DISCORD_TOKEN=your-discord-bot-token
DISCORD_CLIENT_ID=your-discord-application-id
# Your Discord user ID (bot super-admin) and the guild (server) to configure.
DISCORD_ADMIN_USER_ID=your-discord-user-id
DISCORD_GUILD_ID=your-discord-guild-id

# ── Discord channels for the default guild (template seed) ────────────────
# Channel IDs the template wires up. Leave blank to disable a feature; you can
# also change any of this later in the dashboard or config.json.
DISCORD_NOTIFICATIONS_CHANNEL_ID=
DISCORD_CHAT_BRIDGE_CHANNEL_ID=
DISCORD_LEADERBOARD_CHANNEL_ID=

# ── Minecraft server API (template seed) ──────────────────────────────────
# The server-control API wrapper the bot talks to (https recommended).
MC_API_URL=
MC_API_KEY=
# RCON password — overrides config.json for ALL servers at load time.
RCON_PASSWORD=
# Per-server override: RCON_PASSWORD_<SERVER_ID_UPPERCASED>
# RCON_PASSWORD_SURVIVAL=server-specific-password

# ── Web dashboard (only used with --profile web) ──────────────────────────
# The dashboard boots without these, but Discord OAuth login needs them.
# Add <publicUrl>/auth/callback to the Discord app's OAuth2 redirect URIs.
WEBUI_CLIENT_SECRET=
# Cookie-signing key — any long random string (>= 16 chars).
WEBUI_SESSION_SECRET=
# Where the dashboard is published on the HOST. Loopback only by default;
# set 0.0.0.0 to expose on the LAN — only behind a TLS reverse proxy.
WEBUI_BIND_ADDR=127.0.0.1
WEBUI_PORT=8130
# Bearer token gating GET /metrics (player names + infra state). Unset = open.
WEBUI_METRICS_TOKEN=

# ── Deployment knobs (optional) ───────────────────────────────────────────
# Timezone for logs/timestamps (e.g. Europe/Berlin). Default: UTC.
# TZ=UTC
# Verbose logging.
# DEBUG=true
# Log rotation for the container's json-file driver.
# LOG_MAX_SIZE=10m
# LOG_MAX_FILE=3

# ── Config seeding (advanced) ─────────────────────────────────────────────
# Use a static, fully-filled config instead of the env-substituted template:
# point this at your file and it's copied in as-is on first start.
# MCBOT_CONFIG_FILE=./config.json
# Use a template in a non-default location.
# MCBOT_CONFIG_TEMPLATE=./config.template.json

# ── Data layer (advanced) ─────────────────────────────────────────────────
# Active config.json location (both processes must agree). Default in Docker:
# /app/data/config.json (the writable volume, so the dashboard can edit it).
# MCBOT_CONFIG_PATH=/app/data/config.json
# SQLite store location override (both processes must agree).
# MCBOT_DB_PATH=/somewhere/else/bot.db
# SQLite driver. Bot defaults to better-sqlite3; the dashboard defaults to the
# built-in node:sqlite (no native build). "node" requires Node >= 22.13.
# MCBOT_SQLITE_DRIVER=node
