{
  "name": "minecraft-bot",
  "version": "3.5.1",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LetsGaming/minecraft-bot.git"
  },
  "engines": {
    "node": ">=18"
  },
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node --enable-source-maps dist/index.js",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --max-warnings 0",
    "pm2:start": "pm2 start ecosystem.config.cjs --env production",
    "pm2:stop": "pm2 stop minecraft-bot",
    "pm2:restart": "npm run build && pm2 restart minecraft-bot",
    "pm2:logs": "pm2 logs minecraft-bot",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "setup": "node scripts/setup.mjs"
  },
  "dependencies": {
    "discord.js": "^14.26.4"
  },
  "overrides": {
    "undici": "^6.27.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.60.1",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^10.4.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
