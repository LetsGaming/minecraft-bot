{
  "name": "minecraft-bot",
  "version": "4.4.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LetsGaming/minecraft-bot.git"
  },
  "engines": {
    "node": ">=20"
  },
  "type": "module",
  "private": true,
  "workspaces": [
    "src/schema",
    "src/core",
    "src/bot",
    "src/web"
  ],
  "scripts": {
    "build": "npm run schema:generate && tsc -b src/bot",
    "build:web": "npm run build --workspace=@mcbot/web",
    "build:all": "npm run schema:generate && tsc -b src/bot src/web && npm run build:frontend --workspace=@mcbot/web",
    "start": "node --enable-source-maps src/bot/dist/index.js",
    "start:web": "node --enable-source-maps src/web/dist/backend/index.js",
    "dev": "tsc -b src/bot src/web --watch",
    "typecheck": "tsc -b src/bot src/web",
    "lint": "eslint src --max-warnings 0",
    "pm2:start": "pm2 start ecosystem.config.cjs --env production",
    "pm2:stop": "pm2 stop minecraft-bot",
    "pm2:restart": "npm run build && pm2 restart minecraft-bot",
    "pm2:logs": "pm2 logs minecraft-bot",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "setup": "node scripts/setup.mjs",
    "schema:generate": "node scripts/generate-schema.mjs",
    "schema:check": "node scripts/generate-schema.mjs --check",
    "i18n:check": "node scripts/check-locales.mjs",
    "bump-version": "node scripts/bump-version.mjs",
    "clean": "rm -rf src/*/dist",
    "e2e:smoke": "node scripts/e2e-smoke.mjs",
    "e2e:contract": "node scripts/e2e-wrapper-contract.mjs"
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.60.1",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^10.4.1",
    "ts-json-schema-generator": "^2.9.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "overrides": {
    "undici": "^6.27.0"
  }
}
