# Dependencies and build output — rebuilt inside the image
node_modules/
**/node_modules/
**/dist/
**/*.tsbuildinfo

# Secrets and local config — never bake into an image
.env
.env.*
config.json
config.template.json

# Runtime data — provided via volumes
logs/
data/linkedAccounts.json
data/linkCodes.json
data/claimedDaily.json
data/whitelistAudit.json
data/leaderboardSchedule.json
data/statusMessages.json
data/snapshots/
data/bot.db*
data/*.imported

# Repo metadata and docs — not needed in the image
.git/
.gitignore
tests/
docs/
*.md
